{
  "name": "leish-clone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "preview:full": "npm run build && tsx scripts/preview.ts",
    "api:serve": "tsx watch scripts/api-server.ts",
    "dev:full": "concurrently -n api,vite -c blue,green \"npm run api:serve\" \"npm run dev\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "axios": "^1.18.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "@tailwindcss/postcss",
      "unrs-resolver"
    ]
  }
}
