{
  "name": "leish-clone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "preview:full": "npm run build && tsx scripts/preview.ts",
    "api:serve": "tsx watch scripts/api-server.ts",
    "dev:full": "concurrently -n api,vite -c blue,green \"npm run api:serve\" \"npm run dev\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "test:e2e": "playwright test",
    "check:email": "tsx scripts/check-email.ts",
    "analyze": "vite build --mode analyz",
    "report": "vite build --mode report && open stats.html"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "@neondatabase/neon-js": "^0.6.2-beta",
    "@neondatabase/serverless": "^1.0.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "playwright": "^1.61.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "@tailwindcss/postcss",
      "unrs-resolver"
    ]
  }
}
