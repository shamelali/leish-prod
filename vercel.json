{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/cron?action=cleanup", "schedule": "0 0 * * *" },
    { "path": "/api/cron?action=reminders", "schedule": "0 9 * * *" },
    { "path": "/api/cron?action=booking-cleanup", "schedule": "0 6 * * *" },
    { "path": "/api/cron?action=release-escrow", "schedule": "0 8 * * *" }
  ]
}
